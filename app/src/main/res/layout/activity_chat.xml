<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginStart="0dp"
    android:layout_marginEnd="0dp"
    android:layout_marginBottom="20dp"
    android:background="@color/bg_normal"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- App header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp"
            android:paddingBottom="10dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk"
                android:letterSpacing="0.02"
                android:text="AI Hub ・ チャット"
                android:textColor="@color/on_surface"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Model selector chip -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_chip">

            <Spinner
                android:id="@+id/sp_model_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingLeft="14dp"
                android:paddingRight="8dp"
                android:spinnerMode="dropdown"
                android:dropDownWidth="match_parent"
                android:dropDownVerticalOffset="52dp"
                android:popupBackground="@drawable/bg_dropdown" />

            <View
                android:id="@+id/v_tip"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:visibility="gone" />
        </FrameLayout>


        <!-- Control buttons section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_download"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/btn_rounded_border"
                android:text="Download"
                android:textAllCaps="false"
                android:textColor="@color/on_surface" />

            <Button
                android:id="@+id/btn_load_model"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/btn_rounded_border"
                android:text="Load"
                android:textAllCaps="false"
                android:textColor="@color/on_surface" />

            <Button
                android:id="@+id/btn_unload_model"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/btn_rounded_border"
                android:text="Unload"
                android:textAllCaps="false"
                android:textColor="@color/on_surface"
                android:visibility="gone"
                tools:visibility="gone" />

            <Button
                android:id="@+id/btn_stop"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/btn_rounded_border"
                android:text="Stop"
                android:textAllCaps="false"
                android:textColor="@color/on_surface"
                android:visibility="gone"
                tools:visibility="gone" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="@color/divider" />

        <Button
            android:id="@+id/btn_test"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="test"
            android:visibility="gone" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- chat display area -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_chat"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:padding="8dp"
                        android:scrollbars="vertical"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                    <!-- Welcome / empty state -->
                    <LinearLayout
                        android:id="@+id/ll_empty"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingStart="32dp"
                        android:paddingEnd="32dp">

                        <ImageView
                            android:layout_width="76dp"
                            android:layout_height="76dp"
                            android:alpha="0.95"
                            android:src="@drawable/ic_logo" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:fontFamily="@font/space_grotesk"
                            android:letterSpacing="0.02"
                            android:text="オンデバイス チャット"
                            android:textColor="@color/on_surface"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="Snapdragon上で動くオンデバイスAI\nモデルを選んで Load すると始められる"
                            android:textColor="@color/on_surface_dim"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="26dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/chip_s1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:background="@drawable/bg_chip"
                                android:paddingStart="18dp"
                                android:paddingTop="12dp"
                                android:paddingEnd="18dp"
                                android:paddingBottom="12dp"
                                android:text="この文章を要約して"
                                android:textColor="@color/on_surface"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/chip_s2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:background="@drawable/bg_chip"
                                android:paddingStart="18dp"
                                android:paddingTop="12dp"
                                android:paddingEnd="18dp"
                                android:paddingBottom="12dp"
                                android:text="Pythonで簡単なコードを書いて"
                                android:textColor="@color/on_surface"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/chip_s3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_chip"
                                android:paddingStart="18dp"
                                android:paddingTop="12dp"
                                android:paddingEnd="18dp"
                                android:paddingBottom="12dp"
                                android:text="オンデバイスAIの利点を教えて"
                                android:textColor="@color/on_surface"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>

                <!-- Input section at bottom -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/bg_composer"
                    android:orientation="vertical"
                    android:paddingLeft="14dp"
                    android:paddingTop="8dp"
                    android:paddingRight="14dp"
                    android:paddingBottom="4dp">

                    <HorizontalScrollView
                        android:id="@+id/scroll_images"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_margin="6dp"
                        android:overScrollMode="never"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/ll_images_container"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="6dp"
                            android:layout_marginEnd="6dp"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <EditText
                        android:id="@+id/et_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="6dp"
                        android:background="@null"
                        android:hint="Type prompt..."
                        android:padding="6dp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/hint"
                        android:imeOptions="actionSend"
                        android:inputType="text" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="4dp"
                            android:layout_weight="1"
                            android:gravity="start"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btn_add_image"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginLeft="4dp"
                                android:layout_marginRight="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/btn_ghost"
                                android:ellipsize="end"
                                android:singleLine="true"
                                android:stateListAnimator="@null"
                                android:text="+ Image"
                                android:textAllCaps="false"
                                android:textColor="@color/on_surface"
                                android:visibility="invisible" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btn_clear_history"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginRight="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/btn_ghost"
                                android:ellipsize="end"
                                android:singleLine="true"
                                android:stateListAnimator="@null"
                                android:text="Clear"
                                android:textAllCaps="false"
                                android:textColor="@color/on_surface_dim" />

                            <Button
                                android:id="@+id/btn_send"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:background="@drawable/btn_send_primary"
                                android:ellipsize="end"
                                android:singleLine="true"
                                android:stateListAnimator="@null"
                                android:text="Send"
                                android:textAllCaps="false"
                                android:textStyle="bold"
                                android:textColor="@color/btn_send_text" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <!-- Download progress overlay -->
    <LinearLayout
        android:id="@+id/ll_downloading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_normal"
        android:clickable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="invisible"
        tools:visibility="visible">

        <ProgressBar
            android:id="@+id/pb_downloading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/tv_download_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/accent_cyan"
            android:textSize="16sp"
            android:text="0%" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_cancel_download"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:background="@drawable/btn_rounded_border"
                android:text="cancel"
                android:textColor="@color/on_surface"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_retry_download"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginLeft="20dp"
                android:background="@drawable/btn_rounded_border_18"
                android:text="retry"
                android:textColor="@color/accent_cyan"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_normal"
        android:clickable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="invisible"
        tools:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/on_surface"
            android:text="Loading" />
    </LinearLayout>

</RelativeLayout>
