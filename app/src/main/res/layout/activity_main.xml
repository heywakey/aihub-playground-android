<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context=".MainActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.aihub.playground.ui.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#66000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@android:color/white"
            android:contentDescription="戻る" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="物体検出 ・ YOLOX" />

        <ImageButton
            android:id="@+id/flipButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="@android:color/white"
            android:contentDescription="カメラ切替" />
    </LinearLayout>

    <!-- ROI 操作ヒント(超解像/セグ/深度) -->
    <TextView
        android:id="@+id/roiHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="64dp"
        android:background="#80000000"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        android:text="枠をドラッグで移動 ・ ピンチで拡大縮小"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- 検出しきい値パネル(物体検出のみ) -->
    <LinearLayout
        android:id="@+id/thresholdPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#99000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/scoreLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            tools:text="スコア閾値 0.40" />

        <SeekBar
            android:id="@+id/scoreSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="95"
            android:progress="40" />

        <TextView
            android:id="@+id/iouLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            tools:text="IoU 閾値 0.50" />

        <SeekBar
            android:id="@+id/iouSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="95"
            android:progress="50" />
    </LinearLayout>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="56dp"
        android:layout_marginEnd="12dp"
        android:background="#80000000"
        android:padding="6dp"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        tools:text="30 fps / infer 27ms / QNN-HTP(NPU)" />

</FrameLayout>
