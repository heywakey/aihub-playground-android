<?xml version="1.0" encoding="utf-8"?>
<!-- チャットを離れずに撮影する全画面ライブカメラ。CameraX Preview + ImageCapture。 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- タップフォーカスの合焦枠(タップ位置に一瞬表示) -->
    <View
        android:id="@+id/focusRing"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/ic_focus_ring"
        android:visibility="gone" />

    <!-- 上部: 閉じる -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="@drawable/bg_capture_circle"
        android:src="@drawable/icon_close"
        android:scaleType="centerInside"
        android:padding="10dp"
        android:contentDescription="閉じる" />

    <!-- 上部: フラッシュ切替(OFF/ON/AUTO) -->
    <ImageButton
        android:id="@+id/btnFlash"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="@drawable/bg_capture_circle"
        android:src="@drawable/ic_flash_off"
        android:scaleType="centerInside"
        android:padding="10dp"
        android:contentDescription="フラッシュ切替" />

    <!-- 下部スクリム -->
    <View
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_gravity="bottom"
        android:background="#99000000" />

    <!-- シャッター(下部中央) -->
    <ImageButton
        android:id="@+id/btnShutter"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_shutter"
        android:scaleType="fitCenter"
        android:contentDescription="撮影" />

    <!-- カメラ切替(下部右) -->
    <ImageButton
        android:id="@+id/btnFlip"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="36dp"
        android:layout_marginBottom="44dp"
        android:background="@drawable/bg_capture_circle"
        android:src="@drawable/ic_flip_camera"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:contentDescription="カメラ切替" />

</FrameLayout>
